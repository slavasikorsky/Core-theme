{{ 'hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .hero {
    --bg-color: {{ section.settings.background_color }};
    --heading-color: {{ section.settings.heading_color }};
    --subtext-color: {{ section.settings.subtext_color }};
  }
{%- endstyle -%}

<section
  class="hero full-width"
  style="
    --section-height: {{ section.settings.size }};
    --text-position: {{ section.settings.text_position }};
    --text-align: {%- if section.settings.center_text -%}center{%- else -%}start{%- endif -%};
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --padding-top: {{ section.settings.padding_top_desktop }}px;
    --padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    --padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  {%- if section.settings.background_image -%}
    <div class="hero__background">
      <picture>
        {%- if section.settings.mobile_background_image -%}
          <source
            media="(max-width: 767px)"
            srcset="{{ section.settings.mobile_background_image | image_url: width: 800 }}"
          >
        {%- endif -%}
        {{ section.settings.background_image | image_url: width: 2000 | image_tag: loading: 'eager', alt: '' }}
      </picture>
    </div>
    <div class="hero__overlay"></div>
  {%- endif -%}

  <div class="container">
    <div class="hero__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="hero__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="hero__subtext">{{ section.settings.subtext | newline_to_br }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_url | default: routes.root_url }}"
          class="button"
        >
          <span>
            {{- section.settings.button_label | escape -}}
          </span>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:general.hero",
  "settings": [
    {
      "type": "header",
      "content": "t:headers.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Hero heading"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "t:labels.subtext",
      "default": "Add a short description to introduce your brand or promotion."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    },
    {
      "type": "header",
      "content": "t:headers.colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "t:labels.heading_color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "t:labels.subtext_color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "t:headers.background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:labels.background_image"
    },
    {
      "type": "image_picker",
      "id": "mobile_background_image",
      "label": "t:labels.mobile_background_image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background_color",
      "default": "#f4f4f4"
    },
    {
      "type": "paragraph",
      "content": "t:paragraphs.background_color_note"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:labels.overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "t:headers.layout"
    },
    {
      "type": "select",
      "id": "size",
      "label": "t:labels.size",
      "options": [
        { "value": "30rem", "label": "t:options.size.small" },
        { "value": "50rem", "label": "t:options.size.medium" },
        { "value": "70rem", "label": "t:options.size.large" }
      ],
      "default": "50rem"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "t:labels.text_position",
      "options": [
        { "value": "flex-start", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "flex-end", "label": "t:options.alignment.right" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "center_text",
      "label": "t:labels.center_text",
      "default": true
    },
    {
      "type": "header",
      "content": "t:headers.spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "t:labels.padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "t:labels.padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "t:labels.padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "t:labels.padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "t:general.hero"
    }
  ]
}
{% endschema %}
