<header class="header header--logo-{{ section.settings.logo_position }}">
  <div class="header__logo">
    <h2 class="header__title">
      <a href="{{ routes.root_url }}">
        {% if settings.logo %}
          {{ settings.logo | image_url: width: settings.logo_width | image_tag: alt: shop.name }}
        {% else %}
          {{ shop.name }}
        {% endif %}
      </a>
    </h2>
  </div>

  <div class="header__menu">
    {% for link in section.settings.menu.links %}
      {{ link.title | link_to: link.url }}
    {% endfor %}
  </div>

  <div class="header__icons">
    {% if section.settings.show_account_icon and shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    {% if section.settings.show_cart_icon %}
      <a href="{{ routes.cart_url }}">
        {% if cart.item_count > 0 %}
          <sup>{{ cart.item_count }}</sup>
        {% endif %}

        {{ 'icon-cart.svg' | inline_asset_content }}
      </a>
    {% endif %}
  </div>
</header>

{% stylesheet %}
  header {
    height: 5rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }
  header a {
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  header a sup {
    position: absolute;
    left: 100%;
    overflow: hidden;
    max-width: var(--page-margin);
  }
  header svg {
    width: 2rem;
  }
  header .header__menu,
  header .header__icons {
    display: flex;
    gap: 1rem;
  }
  header .header__logo {
    grid-area: logo;
  }
  header .header__menu {
    grid-area: menu;
  }
  header .header__icons {
    grid-area: icons;
  }
  header.header--logo-left {
    grid-template-areas: "logo menu icons";
  }
  header.header--logo-left .header__logo {
    justify-self: start;
  }
  header.header--logo-left .header__menu {
    justify-self: center;
  }
  header.header--logo-left .header__icons {
    justify-self: end;
  }
  header.header--logo-center {
    grid-template-areas: "menu logo icons";
  }
  header.header--logo-center .header__menu {
    justify-self: start;
  }
  header.header--logo-center .header__logo {
    justify-self: center;
  }
  header.header--logo-center .header__icons {
    justify-self: end;
  }
  header.header--logo-right {
    grid-template-areas: "icons menu logo";
  }
  header.header--logo-right .header__icons {
    justify-self: start;
  }
  header.header--logo-right .header__menu {
    justify-self: center;
  }
  header.header--logo-right .header__logo {
    justify-self: end;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "select",
      "id": "logo_position",
      "label": "t:labels.logo_position",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_account_icon",
      "label": "t:labels.show_account_icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart_icon",
      "label": "t:labels.show_cart_icon",
      "default": true
    }
  ]
}
{% endschema %}
