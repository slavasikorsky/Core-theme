{{ 'header.css' | asset_url | stylesheet_tag }}
<header
  class="header header--logo-{{ section.settings.logo_position }}"
>
  <div class="header__logo">
    <h2 class="header__title">
      <a href="{{ routes.root_url }}">
        {% if settings.logo %}
          {{ settings.logo | image_url: width: settings.logo_width | image_tag: alt: shop.name }}
        {% else %}
          {{ shop.name }}
        {% endif %}
      </a>
    </h2>
  </div>

  <div class="header__menu mobile--hidden">
    {% for link in section.settings.menu.links %}
      {{ link.title | link_to: link.url }}
    {% endfor %}
  </div>

  <div class="header__icons">
    {% if section.settings.show_account_icon and shop.customer_accounts_enabled %}
      <shopify-account>
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    {% if section.settings.show_cart_icon %}
      <a href="{{ routes.cart_url }}" class="header__cart">
        {% if cart.item_count > 0 %}
          <sup>{{ cart.item_count }}</sup>
        {% endif %}
        <span class="visually-hidden">
          {{ 'general.accessibility.cart' | t }}
        </span>

        {{ 'icon-cart.svg' | inline_asset_content }}
      </a>
    {% endif %}
    {% if section.settings.menu.links.size > 0 %}
      <button
        type="button"
        class="header__menu-toggle"
        aria-expanded="false"
        aria-controls="header-mobile-menu"
        aria-label="{{ 'general.accessibility.toggle_menu' | t }}"
      >
        <span class="visually-hidden">
          {{ 'general.accessibility.toggle_menu' | t }}
        </span>
        {{ 'icon-menu.svg' | inline_asset_content }}
      </button>
    {% endif %}
  </div>
</header>

{% if section.settings.menu.links.size > 0 %}
  <div id="header-mobile-menu" class="header__mobile-menu" aria-hidden="true">
    <button
      type="button"
      class="header__mobile-close"
      aria-label="{{ 'general.accessibility.close_menu' | t }}"
    >
      {{ 'icon-close.svg' | inline_asset_content }}
    </button>
    <nav class="header__mobile-nav">
      {% for link in section.settings.menu.links %}
        {{ link.title | link_to: link.url }}
      {% endfor %}
    </nav>
  </div>
  <div class="header__mobile-overlay" aria-hidden="true"></div>
{% endif %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "select",
      "id": "logo_position",
      "label": "t:labels.logo_position",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "checkbox",
      "id": "show_account_icon",
      "label": "t:labels.show_account_icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart_icon",
      "label": "t:labels.show_cart_icon",
      "default": true
    }
  ]
}
{% endschema %}
